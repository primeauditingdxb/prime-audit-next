generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Blog {
  id              Int      @id @default(autoincrement())
  metaTitle       String
  metaDescription String
  canonical       String?
  coverImage      String
  h1Title         String
  date            String
  tags            String[]
  excerpt         String
  content         String   @db.Text
  slug            String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
